# 基础配置
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
PUBLIC_BASE_URL=http://127.0.0.1:5173

# 前端 API 地址。生产环境固定 /api；本地开发走 Vite 代理也用 /api
VITE_API_BASE_URL=/api

# 数据源模式
DATA_SOURCE_MODE=demo_seed
ENABLE_PROVIDER_API=false
DEMO_FALLBACK_ENABLED=true

# 数据库预留，第一阶段不强制启用
DATABASE_URL=postgresql://etf_user:your_password@127.0.0.1:5432/etf_swm_agent

# OpenAI-compatible / 火山方舟模型配置预留
# 火山方舟示例：
# LLM_PROVIDER=volcengine_ark
# LLM_API_MODE=responses
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=doubao-seed-2-0-pro-260215
# LLM_API_KEY=your_ark_api_key
LLM_PROVIDER=openai_compatible
LLM_API_MODE=chat_completions
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_ENABLED=false

# 开发环境默认允许在页面中临时配置模型；生产环境如需页面填 Key 请设为 true
ALLOW_RUNTIME_MODEL_CONFIG=true

# 安全配置
CORS_ORIGIN=http://127.0.0.1:5173
REQUEST_TIMEOUT_MS=30000
LOG_LEVEL=info
